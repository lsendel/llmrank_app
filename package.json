{
  "name": "llm-boost",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "prepare": "husky",
    "deploy:record": "tsx infra/scripts/record-deployment.ts",
    "deploy:rollback": "tsx infra/scripts/rollback-deployment.ts",
    "deploy:rollback:dry-run": "tsx infra/scripts/rollback-deployment.ts --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^9.14.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript": "^5.7",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt --edition 2021"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "@react-pdf/reconciler>scheduler": "0.27.0",
      "minimatch": ">=10.2.3",
      "fast-xml-parser": ">=5.3.8",
      "rollup": ">=4.59.0",
      "basic-ftp": ">=5.2.0",
      "hono": ">=4.12.2",
      "@cloudflare/workers-types": "4.20260228.0"
    }
  },
  "packageManager": "pnpm@9.15.0"
}

